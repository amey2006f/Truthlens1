# Copy to .env and fill in values. Never commit .env.

PORT=5000

# Google Gemini (used when the app model is gemini-2.5-flash)
GEMINI_API_KEY=
# Optional override; default is gemini-2.5-flash (no quotes needed)
# GEMINI_MODEL=gemini-2.5-flash

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# If set, forces OpenAI for all model keys (usually leave unset)
# OPENAI_MODEL=
